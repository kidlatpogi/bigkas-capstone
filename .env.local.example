# Supabase
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_key

# EmailJS - Get from https://emailjs.com
VITE_EMAILJS_SERVICE_ID=service_xxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxx
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# Python / REST API base (prefer VITE_PYTHON_SERVICE_URL; VITE_API_BASE_URL is an accepted alias)
VITE_PYTHON_SERVICE_URL=http://localhost:8000
# VITE_API_BASE_URL=http://localhost:8000

# Features
VITE_ENABLE_SESSION_PERSISTENCE=true
VITE_ENABLE_DAILY_QUOTE_FETCH=true
