# Environment Variables — Supabase BaaS Setup

# Frontend Configuration
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_API_TIMEOUT=30000
VITE_ENABLE_DAILY_QUOTE_FETCH=false
VITE_ENABLE_SESSION_PERSISTENCE=true
VITE_ENFORCE_SERVER_LOGIN_GUARD=true
VITE_ADMIN_LOGIN_SLUG=replace-with-a-long-random-string
VITE_APP_NAME=Bigkas Web

# Optional — used by client-side AI helpers in src/api/aiService.js
# VITE_GEMINI_API_KEY=
# VITE_GROQ_API_KEY=

# Python AI Service (media analysis, script generation, scoring)
# For local dev: http://localhost:8000
# For production: https://your-hugging-face-space-url
VITE_PYTHON_SERVICE_URL=https://your-huggingface-deployment.hf.space
# Optional legacy alias — same base URL if you prefer this name (env.js accepts either)
# VITE_API_BASE_URL=http://localhost:8000

# Values below are for the Python backend / deployment only (not exposed to the Vite client unless also prefixed with VITE_)
# Supabase Configuration (for backend services)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Python AI Service Configuration
JWT_SECRET=your-jwt-secret-key
JWT_ALGORITHM=HS256
HOST=0.0.0.0
PORT=8000
DEBUG=false
CORS_ORIGINS=https://www.bigkas.site,https://bigkas-web.vercel.app,http://localhost:3000,http://localhost:5173
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key
ADMIN_LOGIN_ROUTE_KEY=replace-with-the-same-long-random-string
ADMIN_ALLOWED_EMAILS=admin@bigkas.site
